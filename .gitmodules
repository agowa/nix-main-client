[submodule "etc/nixos/nixpkgs/nixos-25.05"]
	path = etc/nixos/nixpkgs/nixos-25.05
	url = ../nixpkgs
	branch = nixos-25.05
[submodule "etc/nixos/nixpkgs/nixos-25.11"]
	path = etc/nixos/nixpkgs/nixos-25.11
	url = ../nixpkgs
	branch = nixos-25.11
[submodule "etc/nixos/nixpkgs/nixos-26.05"]
	path = etc/nixos/nixpkgs/nixos-26.05
	url = ../nixpkgs
	branch = nixos-26.05
[submodule "etc/nixos/nixpkgs/nixos-unstable"]
	path = etc/nixos/nixpkgs/nixos-unstable
	url = ../nixpkgs
	branch = nixos-unstable
[submodule "etc/nixos/nixpkgs/master"]
	path = etc/nixos/nixpkgs/master
	url = ../nixpkgs
	branch = master
